{% comment %}
  sections/hero-gift-guide.liquid
  "The Gift Guide" hero — Desktop split layout + Mobile stacked
  Pixel-perfect match to Figma design.
{% endcomment %}

{{ 'hero-gift-guide.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign heading       = section.settings.heading       | default: 'The Gift Guide'
  assign subheading    = section.settings.subheading    | default: 'Discover Joy: Your Ultimate Holiday Gift Destination. Explore our curated selection and find the perfect gifts to delight your loved ones this holiday season.'
  assign button_label  = section.settings.button_label  | default: 'SHOP NOW'
  assign button_url    = section.settings.button_url    | default: '#'
  assign bg_image      = section.settings.bg_image
  assign ticker_text   = section.settings.ticker_text   | default: 'SUSTAINABLE, ETHICALLY MADE CLOTHES IN SIZES XXS TO 6XL'
-%}

<section class="hgg" id="shopify-section-{{ section.id }}">

  {%- comment %} ── HERO ─────────────────────────────────────── {%- endcomment %}
  <div class="hgg__hero">

    {%- comment %} Background illustration {%- endcomment %}
    <div class="hgg__bg" aria-hidden="true">
      {%- if bg_image != blank -%}
        {{
          bg_image
          | image_url: width: 1600
          | image_tag:
            loading: "eager",
            fetchpriority: "high",
            class: "hgg__bg-img",
            widths: "750,1100,1400,1600",
            sizes: "100vw",
            alt: ""
        }}
      {%- else -%}
        {{ 'lifestyle-2' | placeholder_svg_tag: 'hgg__bg-img hgg__bg-placeholder' }}
      {%- endif -%}
    </div>

    {%- comment %} Content overlay {%- endcomment %}
    <div class="hgg__content">
      <div class="hgg__text-block">
        <h1 class="hgg__heading">{{ heading }}</h1>
        <p class="hgg__subheading">{{ subheading }}</p>
        <a href="{{ button_url }}" class="hgg__btn" aria-label="{{ button_label }}">
          <span>{{ button_label }}</span>
          <svg width="20" height="12" viewBox="0 0 20 12" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
            <path d="M1 6H19M19 6L14 1M19 6L14 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>

  </div>

  {%- comment %} ── TICKER ───────────────────────────────────── {%- endcomment %}
  <div class="hgg__ticker" aria-label="{{ ticker_text }}">
    <div class="hgg__ticker-track" aria-hidden="true">
      {%- for i in (1..8) -%}
        <span class="hgg__ticker-item">{{ ticker_text }}</span>
        <span class="hgg__ticker-dot" aria-hidden="true">•</span>
      {%- endfor -%}
    </div>
  </div>

</section>

{% schema %}
{
  "name": "Hero – Gift Guide",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background illustration"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Gift Guide"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Discover Joy: Your Ultimate Holiday Gift Destination. Explore our curated selection and find the perfect gifts to delight your loved ones this holiday season."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button URL"
    },
    {
      "type": "text",
      "id": "ticker_text",
      "label": "Ticker text",
      "default": "SUSTAINABLE, ETHICALLY MADE CLOTHES IN SIZES XXS TO 6XL"
    }
  ],
  "presets": [
    {
      "name": "Hero – Gift Guide"
    }
  ]
}
{% endschema %}


<style>
/* ==========================================================
   hero-gift-guide.css
   Pixel-perfect Figma match — Desktop split + Mobile stacked
   ========================================================== */

/* ---------- Reset / base ---------- */
.hgg *,
.hgg *::before,
.hgg *::after {
  box-sizing: border-box;
}

/* ---------- Section wrapper ---------- */
.hgg {
  font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
  background: #f5f5f5;
}

/* ==========================================================
   HERO
   ========================================================== */
.hgg__hero {
  position: relative;
  width: 100%;
  min-height: 100vh;          /* full viewport on desktop */
  overflow: hidden;
  background: #f5f5f5;
  display: flex;
  align-items: flex-end;      /* content anchors to bottom-left */
}

/* ---------- Background illustration ---------- */
.hgg__bg {
  position: absolute;
  inset: 0;
  z-index: 0;
}

.hgg__bg-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center top;
  display: block;
}

.hgg__bg-placeholder {
  width: 100%;
  height: 100%;
  opacity: 0.25;
}

/* ---------- Content overlay ---------- */
.hgg__content {
  position: relative;
  z-index: 1;
  width: 100%;
  padding: 0 80px 80px;
  display: flex;
  align-items: flex-end;
}

.hgg__text-block {
  max-width: 520px;
}

/* ---------- Heading ---------- */
.hgg__heading {
  font-size: 72px;
  font-weight: 700;
  line-height: 1.0;
  letter-spacing: -1.5px;
  color: #111;
  margin: 0 0 20px;
}

/* ---------- Subheading ---------- */
.hgg__subheading {
  font-size: 16px;
  font-weight: 400;
  line-height: 1.55;
  color: #111;
  margin: 0 0 36px;
  max-width: 420px;
}

/* ---------- CTA Button ---------- */
.hgg__btn {
  display: inline-flex;
  align-items: center;
  gap: 16px;
  background: #111;
  color: #fff;
  text-decoration: none;
  font-size: 13px;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  padding: 18px 28px;
  transition: background 0.2s ease;
  white-space: nowrap;
}

.hgg__btn:hover {
  background: #333;
}

.hgg__btn svg {
  flex-shrink: 0;
  transition: transform 0.2s ease;
}

.hgg__btn:hover svg {
  transform: translateX(4px);
}

/* ==========================================================
   TICKER
   ========================================================== */
.hgg__ticker {
  background: #f5f5f5;
  border-top: 1px solid #e0e0e0;
  border-bottom: 1px solid #e0e0e0;
  overflow: hidden;
  white-space: nowrap;
  padding: 14px 0;
}

.hgg__ticker-track {
  display: inline-flex;
  align-items: center;
  gap: 0;
  animation: hgg-ticker 28s linear infinite;
  will-change: transform;
}

.hgg__ticker-item {
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: #111;
  padding: 0 24px;
}

.hgg__ticker-dot {
  color: #111;
  font-size: 11px;
  flex-shrink: 0;
}

@keyframes hgg-ticker {
  0%   { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}

/* ==========================================================
   DESKTOP NAV (rendered by theme — supplemental overrides)
   The Figma nav has: logo left, tagline center, yellow CTA right.
   These classes target Dawn's header if customized via theme settings.
   ========================================================== */

/* ==========================================================
   RESPONSIVE — TABLET (≤1024px)
   ========================================================== */
@media (max-width: 1024px) {
  .hgg__hero {
    min-height: 70vh;
  }

  .hgg__content {
    padding: 0 48px 60px;
  }

  .hgg__heading {
    font-size: 52px;
  }
}

/* ==========================================================
   RESPONSIVE — MOBILE (≤749px)
   Layout:
     [ The Gift Guide  ]  ← heading, normal flow above image
     [ Discover Joy... ]  ← subheading, normal flow above image
     [  illustration   ]  ← image fills remaining area
     [  SHOP NOW →    ]  ← button absolute, overlaps bottom of image
   ========================================================== */
@media (max-width: 749px) {
  .hgg__hero {
    /* Stack vertically: content div on top, bg image below */
    display: flex;
    flex-direction: column;
    min-height: unset;
    height: auto;
    align-items: stretch;
  }

  /* Image: pulled out of absolute, becomes a normal flow block below text */
  .hgg__bg {
    position: relative;
    inset: unset;
    order: 2;
    width: 100%;
    height: 360px;
    flex-shrink: 0;
    /* Hero still needs position:relative so btn can be absolute over it */
  }

  .hgg__bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }

  /* Content: normal flow on top, no longer absolute */
  .hgg__content {
    position: relative;
    order: 1;
    padding: 36px 24px 24px;
    width: 100%;
    /* Override desktop align-items:flex-end — text should be top */
    align-items: flex-start;
    background: #f5f5f5;
  }

  .hgg__text-block {
    max-width: 100%;
    width: 100%;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .hgg__heading {
    font-size: 36px;
    letter-spacing: -0.5px;
    margin-bottom: 12px;
    line-height: 1.1;
  }

  .hgg__subheading {
    font-size: 14px;
    line-height: 1.5;
    max-width: 300px;
    margin-bottom: 0;
  }

  /* Button: in HTML it's inside .hgg__text-block, but on mobile
     we make it position:absolute relative to .hgg__hero so it
     floats over the illustration below the text block */
  .hgg__btn {
    position: absolute;
    bottom: 48px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    font-size: 12px;
    padding: 16px 32px;
    gap: 14px;
    /* Ensure it escapes .hgg__text-block — works because
       .hgg__hero is position:relative (the containing block) */
  }

  /* Ticker */
  .hgg__ticker-item {
    font-size: 10px;
    padding: 0 16px;
  }
}

</style>