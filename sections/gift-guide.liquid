{% liquid
  if section.settings.background_color != blank
    render 'contrast-override', background_color: section.settings.background_color, section_id: section.id
  endif
%}

{{ 'gift-guide.css' | asset_url | stylesheet_tag }}

<div
  class="section-background{% if section.settings.background_color != blank %} color-custom-{{ section.id }}{% endif %}"
></div>

<div
  class="section spacing-style gift-guide-section{% if section.settings.background_color != blank %} color-custom-{{ section.id }}{% endif %}"
  style="
    {%- render 'spacing-padding', settings: section.settings -%}
    --section-max-width: {{ section.settings.section_width }}px;
    --section-gap: {{ section.settings.section_gap }}px;
    --gift-guide-text-color: {{ section.settings.text_color }};
    --gift-guide-button-primary-bg: {{ section.settings.button_primary_bg }};
    --gift-guide-button-primary-text: {{ section.settings.button_primary_text }};
    --gift-guide-button-secondary-bg: {{ section.settings.button_secondary_bg }};
    --gift-guide-button-secondary-text: {{ section.settings.button_secondary_text }};
  "
  data-section-id="{{ section.id }}"
>
  <div class="gift-guide__container">
    <div class="gift-guide__content">
      {% if section.settings.brand_label != blank %}
        <div class="gift-guide__brand">
          {{ section.settings.brand_label }}
        </div>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h1 class="gift-guide__heading">
          {{ section.settings.heading }}
        </h1>
      {% endif %}

      {% if section.settings.subheading != blank %}
        <p class="gift-guide__subheading">
          {{ section.settings.subheading }}
        </p>
      {% endif %}

      {% if section.settings.description != blank %}
        <div class="gift-guide__description rte">
          {{ section.settings.description }}
        </div>
      {% endif %}

      {% if section.blocks.size > 0 %}
        <div class="gift-guide__buttons">
          {% for block in section.blocks %}
            {% case block.type %}
              {% when 'button' %}
                <a
                  href="{{ block.settings.button_link }}"
                  class="gift-guide__button gift-guide__button--{{ block.settings.button_style }}"
                  {{ block.shopify_attributes }}
                >
                  {{ block.settings.button_text }}
                </a>
            {% endcase %}
          {% endfor %}
        </div>
      {% endif %}
    </div>

    <div class="gift-guide__media">
      {% if section.settings.image_1 != blank %}
        <div class="gift-guide__image gift-guide__image--1">
          <img
            src="{{ section.settings.image_1 | img_url: '300x300' }}"
            width="300"
            height="300"
            alt="{{ section.settings.heading }}"
            loading="lazy"
            class="gift-guide__img"
          />
        </div>
      {% endif %}

      {% if section.settings.image_2 != blank %}
        <div class="gift-guide__image gift-guide__image--2">
          <img
            src="{{ section.settings.image_2 | img_url: '250x250' }}"
            width="250"
            height="250"
            alt="{{ section.settings.heading }}"
            loading="lazy"
            class="gift-guide__img"
          />
        </div>
      {% endif %}

      {% if section.settings.image_3 != blank %}
        <div class="gift-guide__image gift-guide__image--3">
          <img
            src="{{ section.settings.image_3 | img_url: '280x280' }}"
            width="280"
            height="280"
            alt="{{ section.settings.heading }}"
            loading="lazy"
            class="gift-guide__img"
          />
        </div>
      {% endif %}

      {% if section.settings.image_4 != blank %}
        <div class="gift-guide__image gift-guide__image--4">
          <img
            src="{{ section.settings.image_4 | img_url: '320x320' }}"
            width="320"
            height="320"
            alt="{{ section.settings.heading }}"
            loading="lazy"
            class="gift-guide__img"
          />
        </div>
      {% endif %}

      {% if section.settings.image_5 != blank %}
        <div class="gift-guide__image gift-guide__image--5">
          <img
            src="{{ section.settings.image_5 | img_url: '270x270' }}"
            width="270"
            height="270"
            alt="{{ section.settings.heading }}"
            loading="lazy"
            class="gift-guide__img"
          />
        </div>
      {% endif %}

      {% if section.settings.image_6 != blank %}
        <div class="gift-guide__image gift-guide__image--6">
          <img
            src="{{ section.settings.image_6 | img_url: '260x260' }}"
            width="260"
            height="260"
            alt="{{ section.settings.heading }}"
            loading="lazy"
            class="gift-guide__img"
          />
        </div>
      {% endif %}
    </div>
  </div>
</div>

{{ 'gift-guide.js' | asset_url | script_tag }}

{% schema %}
{
  "name": "Gift Guide",
  "tag": "section",
  "class": "gift-guide",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "blocks": [
    {
      "type": "button",
      "name": "Button",
      "limit": 2,
      "settings": [
        {
          "type": "text",
          "id": "button_text",
          "label": "Button text",
          "default": "Shop Now"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        },
        {
          "type": "select",
          "id": "button_style",
          "label": "Button style",
          "options": [
            {
              "value": "primary",
              "label": "Primary"
            },
            {
              "value": "secondary",
              "label": "Secondary"
            }
          ],
          "default": "primary"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "brand_label",
      "label": "Brand label",
      "default": "TISSO VISON"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>The Gift Guide</p>"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Subheading",
      "default": "<p>Find the ideal gift for your loved ones.</p>"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Discover joy. Your Ultimate Holiday Gift Destination. Explore our curated selection and find the perfect gifts to delight your loved ones this holiday season.</p>"
    },
    {
      "type": "header",
      "content": "Media"
    },
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "Image 1"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Image 2"
    },
    {
      "type": "image_picker",
      "id": "image_3",
      "label": "Image 3"
    },
    {
      "type": "image_picker",
      "id": "image_4",
      "label": "Image 4"
    },
    {
      "type": "image_picker",
      "id": "image_5",
      "label": "Image 5"
    },
    {
      "type": "image_picker",
      "id": "image_6",
      "label": "Image 6"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "section_width",
      "min": 800,
      "max": 1400,
      "step": 50,
      "unit": "px",
      "label": "Section max width",
      "default": 1200
    },
    {
      "type": "range",
      "id": "section_gap",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "px",
      "label": "Gap between content and media",
      "default": 60
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_primary_bg",
      "label": "Primary button background",
      "default": "#FFE500"
    },
    {
      "type": "color",
      "id": "button_primary_text",
      "label": "Primary button text",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_secondary_bg",
      "label": "Secondary button background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_secondary_text",
      "label": "Secondary button text",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_left",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding left",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_right",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding right",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "Gift Guide",
      "blocks": [
        {
          "type": "button",
          "settings": {
            "button_text": "CHOOSE GIFT",
            "button_style": "primary"
          }
        },
        {
          "type": "button",
          "settings": {
            "button_text": "SHOP NOW",
            "button_style": "secondary"
          }
        }
      ]
    }
  ]
}
{% endschema %}
