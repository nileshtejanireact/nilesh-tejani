{% liquid
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
%}

<section
  class="gift-header color-{{ section.settings.color_scheme }}"
  style="
    --padding-top: {{ padding_top }}px;
    --padding-bottom: {{ padding_bottom }}px;
  "
>
  <div class="page-width">
    <div class="gift-header__inner">

      {% for block in section.blocks %}
        {% case block.type %}

          {% when 'logo' %}
            <div
              class="gift-header__logo"
              {{ block.shopify_attributes }}
            >
              {% if block.settings.image != blank %}
                {{
                  block.settings.image
                  | image_url: width: 400
                  | image_tag:
                    loading: 'lazy',
                    widths: '120,180,240,300,400'
                }}
              {% endif %}
            </div>

          {% when 'announcement' %}
            <div
              class="gift-header__announcement"
              {{ block.shopify_attributes }}
            >
              {{ block.settings.text }}
            </div>

          {% when 'button' %}
            <div
              class="gift-header__button"
              {{ block.shopify_attributes }}
            >
              {% if block.settings.label != blank %}
                <a
                  href="{{ block.settings.link }}"
                  class="button"
                >
                  {{ block.settings.label }}
                </a>
              {% endif %}
            </div>

        {% endcase %}
      {% endfor %}

    </div>
  </div>
</section>

<style>
.gift-header{
  padding-top:var(--padding-top);
  padding-bottom:var(--padding-bottom);
}

.gift-header__inner{
  display:grid;
  grid-template-columns:220px 1fr auto;
  gap:24px;
  align-items:center;
}

.gift-header__logo{
  line-height:0;
}

.gift-header__logo img{
  display:block;
  max-width:180px;
  width:100%;
  height:auto;
}

.gift-header__announcement{
  text-align:center;
  font-size:1.4rem;
  line-height:1.5;
}

.gift-header__button{
  display:flex;
  justify-content:flex-end;
}

@media screen and (max-width: 749px){

  .gift-header__inner{
    grid-template-columns:1fr;
    text-align:center;
    gap:16px;
  }

  .gift-header__logo{
    display:flex;
    justify-content:center;
  }

  .gift-header__button{
    justify-content:center;
  }

}
</style>

{% schema %}
{
  "name": "Gift Header",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 20,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 20,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "limit": 1,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Logo image"
        }
      ]
    },
    {
      "type": "announcement",
      "name": "Announcement",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Find the ideal gift for your loved ones."
        }
      ]
    },
    {
      "type": "button",
      "name": "Button",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Choose Gift"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Gift Header",
      "blocks": [
        {
          "type": "logo"
        },
        {
          "type": "announcement"
        },
        {
          "type": "button"
        }
      ]
    }
  ]
}
{% endschema %}