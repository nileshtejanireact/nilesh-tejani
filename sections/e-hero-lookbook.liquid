{% comment %}
  sections/tisso-lookbook.liquid
  "Tisso Vison in the Wild" — Lookbook grid with + hotspot buttons.
  Desktop: 3 cols | Mobile: 2 cols
  Modal: product image + title/price/desc + variant pills + size dropdown + ATC
{% endcomment %}

{{ 'tisso-lookbook.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign section_title  = section.settings.section_title | default: 'Tisso vison in the wild'
  assign desktop_cols   = section.settings.desktop_columns | default: 3
  assign mobile_cols    = section.settings.mobile_columns  | default: 2
  assign gap            = section.settings.grid_gap        | default: 4
-%}

<section
  class="tlb"
  id="shopify-section-{{ section.id }}"
  style="--tlb-desktop-cols:{{ desktop_cols }};--tlb-mobile-cols:{{ mobile_cols }};--tlb-gap:{{ gap }}px;"
>

  {%- if section_title != blank -%}
    <h2 class="tlb__heading">{{ section_title }}</h2>
  {%- endif -%}

  {%- if section.blocks.size > 0 -%}

    <ul class="tlb__grid" role="list">

      {%- for block in section.blocks -%}
        {%- if block.type == 'lookbook_item' -%}

          {%- liquid
            assign blk_image   = block.settings.image
            assign blk_product = all_products[block.settings.product]

            assign p_featured_image_url = ''
            if blk_product != blank and blk_product.featured_image
              assign p_featured_image_url = blk_product.featured_image | image_url: width: 800
            endif

            assign card_alt = ''
            if blk_image and blk_image.alt != blank
              assign card_alt = blk_image.alt
            elsif blk_product != blank
              assign card_alt = blk_product.title
            endif

            assign feat_alt = ''
            if blk_product != blank and blk_product.featured_image
              assign feat_alt = blk_product.featured_image.alt | default: blk_product.title
            endif
          -%}

          {%- comment %} Build product JSON {%- endcomment %}
          {%- if blk_product != blank -%}
            {%- capture blk_product_json -%}
              {
                "id": {{ blk_product.id }},
                "title": {{ blk_product.title | json }},
                "description": {{ blk_product.description | json }},
                "featured_image": {{ p_featured_image_url | json }},
                "price": {{ blk_product.price }},
                "price_formatted": {{ blk_product.price | money | json }},
                "options_with_values": [
                  {%- for option in blk_product.options_with_values -%}
                    {
                      "name": {{ option.name | json }},
                      "position": {{ option.position }},
                      "values": {{ option.values | json }}
                    }{%- unless forloop.last -%},{%- endunless -%}
                  {%- endfor -%}
                ],
                "variants": [
                  {%- for variant in blk_product.variants -%}
                    {
                      "id": {{ variant.id }},
                      "title": {{ variant.title | json }},
                      "price": {{ variant.price }},
                      "price_formatted": {{ variant.price | money | json }},
                      "available": {{ variant.available }},
                      "option1": {{ variant.option1 | json }},
                      "option2": {{ variant.option2 | json }},
                      "option3": {{ variant.option3 | json }}
                    }{%- unless forloop.last -%},{%- endunless -%}
                  {%- endfor -%}
                ]
              }
            {%- endcapture -%}
          {%- endif -%}

          {%- liquid
            assign card_img_url = ''
            if blk_image != blank
              assign card_img_url = blk_image | image_url: width: 800
            elsif blk_product != blank and blk_product.featured_image
              assign card_img_url = blk_product.featured_image | image_url: width: 800
            endif

            assign img_widths = '375,550,800'
            assign img_sizes  = '(min-width: 990px) calc(100vw / ' | append: desktop_cols | append: '), calc(50vw - 8px)'
          -%}

          <li class="tlb__item" {{ block.shopify_attributes }}>
            <div class="tlb__card">

              {%- comment %} Photo {%- endcomment %}
              {%- if blk_image != blank -%}
                {{
                  blk_image
                  | image_url: width: 800
                  | image_tag:
                    loading: "lazy",
                    class: "tlb__card-img",
                    widths: img_widths,
                    sizes: img_sizes,
                    alt: card_alt
                }}
              {%- elsif blk_product != blank and blk_product.featured_image -%}
                {{
                  blk_product.featured_image
                  | image_url: width: 800
                  | image_tag:
                    loading: "lazy",
                    class: "tlb__card-img",
                    widths: img_widths,
                    sizes: img_sizes,
                    alt: feat_alt
                }}
              {%- else -%}
                {{ 'image' | placeholder_svg_tag: 'tlb__card-img tlb__card-placeholder' }}
              {%- endif -%}

              {%- comment %} + Hotspot button {%- endcomment %}
              {%- if blk_product != blank -%}
                <button
                  class="tlb__hotspot"
                  type="button"
                  aria-label="View {{ blk_product.title }}"
                  data-product="{{ blk_product_json | strip | escape }}"
                  data-image="{{ card_img_url | escape }}"
                >
                  <span aria-hidden="true">+</span>
                </button>
              {%- endif -%}

            </div>
          </li>

        {%- endif -%}
      {%- endfor -%}

    </ul>

  {%- else -%}
    {%- if request.design_mode -%}
      <p class="tlb__empty">Add lookbook items using the theme editor.</p>
    {%- endif -%}
  {%- endif -%}

</section>

{%- comment %} ── MODAL (one per page) ──────────────────────────── {%- endcomment %}
{%- unless tlb_modal_rendered -%}
  {%- assign tlb_modal_rendered = true -%}

  <div
    id="tlb-modal"
    class="tlb-modal"
    role="dialog"
    aria-modal="true"
    aria-label="Product details"
    aria-hidden="true"
  >
    <div class="tlb-modal__overlay"></div>

    <div class="tlb-modal__panel">

      {%- comment %} Close {%- endcomment %}
      <button class="tlb-modal__close" type="button" aria-label="Close">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
          <path d="M1 1L13 13M13 1L1 13" stroke="#111" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </button>

      {%- comment %} Top row: image + title/price/desc {%- endcomment %}
      <div class="tlb-modal__inner">
        <div class="tlb-modal__img-wrap">
          <img class="tlb-modal__img" src="" alt="" loading="lazy" width="140" height="175">
        </div>
        <div class="tlb-modal__body">
          <h2 class="tlb-modal__title"></h2>
          <p class="tlb-modal__price" aria-live="polite" aria-atomic="true"></p>
          <div class="tlb-modal__desc"></div>
        </div>
      </div>

      {%- comment %} Options + ATC — full width below header {%- endcomment %}
      <div class="tlb-modal__options" aria-label="Product options"></div>

      <p class="tlb-modal__availability" aria-live="polite" aria-atomic="true"></p>
      <p class="tlb-modal__notice" role="alert" aria-live="polite"></p>

      <div class="tlb-modal__atc-wrap">
        <button type="button" class="tlb-modal__atc" aria-label="Add to cart" disabled>
          <span class="tlb-modal__atc-label">ADD TO CART</span>
          <svg class="tlb-modal__atc-arrow" width="20" height="12" viewBox="0 0 20 12" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
            <path d="M1 6H19M19 6L14 1M19 6L14 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>

    </div>
  </div>

{%- endunless -%}

{% schema %}
{
  "name": "Tisso Lookbook",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "section_title",
      "label": "Section title",
      "default": "Tisso vison in the wild"
    },
    {
      "type": "range",
      "id": "desktop_columns",
      "label": "Desktop columns",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "mobile_columns",
      "label": "Mobile columns",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 2
    },
    {
      "type": "range",
      "id": "grid_gap",
      "label": "Grid gap (px)",
      "min": 0,
      "max": 24,
      "step": 2,
      "default": 4
    }
  ],
  "blocks": [
    {
      "type": "lookbook_item",
      "name": "Lookbook Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Tisso Lookbook",
      "blocks": [
        { "type": "lookbook_item" },
        { "type": "lookbook_item" },
        { "type": "lookbook_item" },
        { "type": "lookbook_item" },
        { "type": "lookbook_item" },
        { "type": "lookbook_item" }
      ]
    }
  ]
}
{% endschema %}
{{ 'tisso-lookbook.js' | asset_url | script_tag }}