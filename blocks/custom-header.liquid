{% assign block_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .custom-header-{{ block_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding_vertical }}px {{ block.settings.padding_horizontal }}px;
  }

  .custom-header__container-{{ block_id }} {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .custom-header__logo-{{ block_id }} {
    flex-shrink: 0;
    font-size: {{ block.settings.logo_font_size }}px;
    font-weight: 700;
    color: {{ block.settings.logo_color }};
    text-decoration: none;
  }

  .custom-header__announcement-{{ block_id }} {
    flex-grow: 1;
    text-align: center;
    font-size: {{ block.settings.announcement_font_size }}px;
    color: {{ block.settings.announcement_color }};
  }

  .custom-header__button-{{ block_id }} {
    flex-shrink: 0;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_background_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: 700;
    border-radius: {{ block.settings.button_border_radius }}px;
    transition: background-color 0.3s ease;
    white-space: nowrap;
  }

  .custom-header__button-{{ block_id }}:hover {
    background-color: {{ block.settings.button_hover_background_color }};
  }

  .custom-header__mobile-menu-{{ block_id }} {
    display: none;
  }

  .custom-header__hamburger-{{ block_id }} {
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .custom-header__hamburger-line-{{ block_id }} {
    width: 24px;
    height: 2px;
    background-color: {{ block.settings.logo_color }};
    transition: all 0.3s ease;
  }

  @media screen and (max-width: 749px) {
    .custom-header__container-{{ block_id }} {
      justify-content: space-between;
    }

    .custom-header__announcement-{{ block_id }} {
      display: none;
    }

    .custom-header__button-{{ block_id }} {
      display: none;
    }

    .custom-header__mobile-menu-{{ block_id }} {
      display: block;
    }
  }
{% endstyle %}

<custom-header-{{ block_id }} class="custom-header-{{ block_id }}" {{ block.shopify_attributes }}>
  <div class="custom-header__container-{{ block_id }}">
    <a href="{{ block.settings.logo_link }}" class="custom-header__logo-{{ block_id }}">
      {{ block.settings.logo_text }}
    </a>

    <div class="custom-header__announcement-{{ block_id }}">
      {{ block.settings.announcement_text }}
    </div>

    <a href="{{ block.settings.button_link }}" class="custom-header__button-{{ block_id }}">
      {{ block.settings.button_text }}
    </a>

    <div class="custom-header__mobile-menu-{{ block_id }}">
      <button class="custom-header__hamburger-{{ block_id }}" aria-label="Open menu">
        <span class="custom-header__hamburger-line-{{ block_id }}"></span>
        <span class="custom-header__hamburger-line-{{ block_id }}"></span>
        <span class="custom-header__hamburger-line-{{ block_id }}"></span>
      </button>
    </div>
  </div>
</custom-header-{{ block_id }}>

<script>
  (function() {
    class CustomHeader{{ block_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.hamburger = this.querySelector('.custom-header__hamburger-{{ block_id }}';
        
        if (this.hamburger) {
          this.hamburger.addEventListener('click', () => {
            alert('Mobile menu functionality can be customized here');
          });
        }
      }
    }

    customElements.define('custom-header-{{ block_id }}', CustomHeader{{ block_id }});
  })();
</script>

